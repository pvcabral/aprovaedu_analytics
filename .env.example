# Copie este arquivo para .env e ajuste os valores.
# O docker-compose lê estas variáveis para subir o Postgres e o dashboard.

POSTGRES_DB=desafio_logap
POSTGRES_USER=logap
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_PORT=5432

# Porta em que o dashboard Streamlit fica exposto no host.
STREAMLIT_PORT=8501
